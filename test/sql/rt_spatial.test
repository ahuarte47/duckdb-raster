# name: test/sql/rt_spatial.test
# description: test spatial_raster extension
# group: [sql]

require raster

statement ok
INSTALL spatial;

statement ok
LOAD spatial;

statement ok
INSTALL json;

statement ok
LOAD json;

query II
SELECT
    id,
    ST_Area(geometry)
FROM
    RT_Read('./test/data/overlay-sample.tiff')
WHERE
    ST_Area(geometry) < 500
;
----
22	320

query II
SELECT
    id,
    metadata->>'transform' AS transform
FROM
    RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
;
----
0	[545539.75,0.5,0.0,4724510.25,0.0,-0.5]

query II
SELECT
    id,
    ST_Area(geometry)
FROM
    RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
WHERE
    ST_Area(geometry) > 500
;
----
0	14400

query II
WITH __clip_layer AS (
    SELECT geom FROM ST_Read('./test/data/CATAST_Pol_Township-PNA.geojson')
),
__dataset AS (
    SELECT
        geometry
    FROM
        __clip_layer,
        RT_Read([
            './test/data/mosaic/SCL.tif-land-clip00.tiff',
            './test/data/mosaic/SCL.tif-land-clip01.tiff',
            './test/data/mosaic/SCL.tif-land-clip10.tiff',
            './test/data/mosaic/SCL.tif-land-clip11.tiff'
        ])
    WHERE
        ST_Intersects(__clip_layer.geom, geometry)
)
SELECT count(*), ST_Area(ST_Union_Agg(geometry)) FROM __dataset;
----
12	78643200.0

query I
SELECT
    ST_Area(
        RT_CubePolygonize(databand_1,
                          tile_x,
                          tile_y,
                         (metadata->>'blocksize_x')::INTEGER,
                         (metadata->>'blocksize_y')::INTEGER,
                         (metadata->>'transform')::DOUBLE[]
        )
    )
FROM
    RT_Read('./test/data/overlay-sample.tiff')
LIMIT 5 OFFSET 18
;
