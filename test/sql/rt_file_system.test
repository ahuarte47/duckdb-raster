# name: test/sql/rt_file_system.test
# description: test raster extension
# group: [sql]

require raster

statement ok
INSTALL httpfs;

statement ok
LOAD httpfs;

statement ok
SELECT RT_GdalConfig('AWS_NO_SIGN_REQUEST', 'YES');

query IIIIII
SELECT
    id, x, y, cols, rows, bbox
FROM
    RT_Read('/vsis3/sentinel-cogs/sentinel-s2-l2a-cogs/30/T/WN/2021/9/S2B_30TWN_20210930_0_L2A/B02.tif')
LIMIT 5
;
