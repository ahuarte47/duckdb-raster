# name: test/sql/rt_read_multi.test
# description: test spatial_raster extension
# group: [sql]

require raster

statement ok
INSTALL json;

statement ok
LOAD json;

query I
SELECT
    COUNT(id)
FROM
    RT_Read([
        './test/data/mosaic/SCL.tif-land-clip00.tiff',
        './test/data/mosaic/SCL.tif-land-clip01.tiff',
        './test/data/mosaic/SCL.tif-land-clip10.tiff',
        './test/data/mosaic/SCL.tif-land-clip11.tiff'
    ])
;
----
3477

query IIIII
SELECT
    CAST(metadata->>'width' AS INTEGER) AS cols,
    CAST(metadata->>'height' AS INTEGER) AS rows,
    CAST(metadata->>'crs' AS VARCHAR) AS crs,
    metadata->>'bounds' AS bounds,
    CAST(metadata->>'bands'->>0->>'nodata' AS DOUBLE) AS nodata
FROM
    RT_Read([
        './test/data/mosaic/SCL.tif-land-clip00.tiff',
        './test/data/mosaic/SCL.tif-land-clip01.tiff',
        './test/data/mosaic/SCL.tif-land-clip10.tiff',
        './test/data/mosaic/SCL.tif-land-clip11.tiff'
    ])
LIMIT 1
;
----
7229	7793	EPSG:32630	[541020.0,4640780.0,685600.0,4796640.0]	-9999.0
