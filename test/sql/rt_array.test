# name: test/sql/rt_array.test
# description: test spatial_raster extension
# group: [sql]

require raster

query IIIIII
WITH __input AS (
    SELECT
        RT_Cube2ArrayInt32(databand_1, false) AS r,
        RT_Cube2ArrayInt32(databand_2, false) AS g,
        RT_Cube2ArrayInt32(databand_3, false) AS b
    FROM
        RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
)
SELECT
    r.cols AS r_cols,
    r.rows AS r_rows,
    g.cols AS g_cols,
    g.rows AS g_rows,
    b.cols AS b_cols,
    b.rows AS b_rows,
FROM
    __input
;
----
320	180	320	180	320	180

query IIIIIIIII
WITH __input AS (
    SELECT
        RT_Cube2ArrayInt32(databand_1, false) AS r,
        RT_Cube2ArrayInt32(databand_2, false) AS g,
        RT_Cube2ArrayInt32(databand_3, false) AS b
    FROM
        RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
)
SELECT
    length(r.values) AS r_len,
    list_extract(r.values, 1) AS r_first,
    list_extract(r.values, length(r.values)) AS r_last,
    length(g.values) AS g_len,
    list_extract(g.values, 1) AS g_first,
    list_extract(g.values, length(g.values)) AS g_last,
    length(b.values) AS b_len,
    list_extract(b.values, 1) AS b_first,
    list_extract(b.values, length(b.values)) AS b_last
FROM
    __input
;
----
57600	60	158	57600	44	165	57600	18	149

query IIIIIIIII
WITH __input AS (
    SELECT
        RT_Cube2ArrayInt32(databand_1, false) AS r,
        RT_Cube2ArrayInt32(databand_2, false) AS g,
        RT_Cube2ArrayInt32(databand_3, false) AS b
    FROM
        RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
)
SELECT
    list_min(r.values) AS r_min,
    list_stddev_pop(r.values) AS r_avg,
    list_max(r.values) AS r_max,
    list_min(g.values) AS g_min,
    list_stddev_pop(g.values) AS g_avg,
    list_max(g.values) AS g_max,
    list_min(b.values) AS b_min,
    list_stddev_pop(b.values) AS b_avg,
    list_max(b.values) AS b_max
FROM
    __input
;
----
0	62.911198	255	0	60.559050	255	0	61.648556	254

query IIIIIIIII
WITH __input AS (
    SELECT
        RT_Cube2ArrayDouble(databand_1, false) AS r,
        RT_Cube2ArrayUint8(databand_2, false) AS g,
        RT_Cube2ArrayFloat(databand_3, false) AS b
    FROM
        RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
)
SELECT
    list_min(r.values) AS r_min,
    list_stddev_pop(r.values) AS r_avg,
    list_max(r.values) AS r_max,
    list_min(g.values) AS g_min,
    list_stddev_pop(g.values) AS g_avg,
    list_max(g.values) AS g_max,
    list_min(b.values) AS b_min,
    list_stddev_pop(b.values) AS b_avg,
    list_max(b.values) AS b_max
FROM
    __input
;
----
0	62.911198	255	0	60.559050	255	0	61.648556	254

query III
WITH __input AS (
    SELECT
        RT_Cube2ArrayInt32(databand_1, false) AS r
    FROM
        RT_Read('./test/data/overlay-sample.tiff', blocksize_x := 512, blocksize_y := 512)
),
__array AS (
    SELECT
        RT_Array2Cube(r.values, 'RAW', r.bands, r.cols, r.rows, r.no_data) AS r_array
    FROM
        __input
),
__blob AS (
    SELECT
        RT_Cube2ArrayFloat(r_array, false) AS r
    FROM
        __array
)
SELECT
    list_min(r.values) AS r_min,
    list_stddev_pop(r.values) AS r_avg,
    list_max(r.values) AS r_max
FROM
    __blob
;
----
0	62.911198	255
